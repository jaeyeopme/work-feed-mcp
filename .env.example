# Docker-first Upwork collector defaults. Running compose is explicit live opt-in.
UPWORK_COLLECTOR_DB=/data/upwork.sqlite
UPWORK_COLLECTOR_INTERVAL_SECONDS=3600
UPWORK_COLLECTOR_MAX_PAGES=5
UPWORK_COLLECTOR_PAGE_SIZE=50
UPWORK_COLLECTOR_QUERIES=
UPWORK_COLLECTOR_MCP_HOST=0.0.0.0
UPWORK_COLLECTOR_MCP_PORT=8000
UPWORK_COLLECTOR_MCP_PATH=/mcp
UPWORK_COLLECTOR_MCP_TRANSPORT=streamable-http
