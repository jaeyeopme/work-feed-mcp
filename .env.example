# Upwork collector Docker runtime configuration.
# Copy to .env, edit only what you need, then run:
#   make up
#   make status

# Live collection is enabled in Docker by default. Set to 0 only for local debugging.
UPWORK_COLLECTOR_LIVE=1

# SQLite path inside the Docker volume. Most users should not change this.
UPWORK_COLLECTOR_DB=/data/upwork.sqlite

# Collection cadence and page limits.
# Defaults collect up to 250 jobs every 60 minutes: 5 pages * 50 jobs.
UPWORK_COLLECTOR_INTERVAL_SECONDS=3600
UPWORK_COLLECTOR_MAX_PAGES=5
UPWORK_COLLECTOR_PAGE_SIZE=50

# Optional comma-separated searches, for example: python,scraping
# Empty means unfiltered/latest jobs.
UPWORK_COLLECTOR_QUERIES=

# Runtime logging.
UPWORK_COLLECTOR_LOG_LEVEL=INFO

# MCP HTTP server settings.
# The Compose file binds the port to 127.0.0.1 on the host.
UPWORK_COLLECTOR_MCP_HOST=0.0.0.0
UPWORK_COLLECTOR_MCP_PORT=8000
UPWORK_COLLECTOR_MCP_PATH=/mcp
UPWORK_COLLECTOR_MCP_TRANSPORT=streamable-http
